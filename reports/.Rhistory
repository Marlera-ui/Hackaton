# ============================================================
# 1. PACOTES
# ============================================================
library(tidyverse)
library(tidyr)
library(sidrar)#
library(geobr)#
library(sf)#
library(nasapower)
library(janitor)
library(lubridate)
library(dplyr)#
library(readxl)
library(leaflet)
library(scales)
library(stringr)#
library(ggplot2)#
library(knitr)
library(htmltools)
mg_municipios <- read_municipality(
code_muni = "MG",
year = 2020,
simplified = TRUE
)
# Força o R a usar a API de internet padrão do Windows (resolve 90% dos problemas de rede locais)
options(download.file.method = "wininet")
# Aumenta o tempo limite de download para 5 minutos (evita que a conexão caia por timeout)
options(timeout = 300)
mg_municipios <- read_municipality(
code_muni = "MG",
year = 2020,
simplified = TRUE,
cache = FALSE        # <--- This forces R to ignore the corrupt file and download fresh
)
# Descubra onde o geobr guarda o cache permanente no seu PC
tools::R_user_dir("geobr", which = "cache")
# Força o R a usar a API de internet padrão do Windows (resolve 90% dos problemas de rede locais)
options(download.file.method = "wininet")
# Aumenta o tempo limite de download para 5 minutos (evita que a conexão caia por timeout)
options(timeout = 300)
unlink(file.path(tempdir(), "geobr"), recursive = TRUE)
mg_municipios <- read_municipality(
code_muni = "MG",
year = 2020,
simplified = TRUE
)
# Criando um caminho temporário para o teste
destino_teste <- tempfile(fileext = ".gpkg")
# Link direto do mapa de municípios de MG (2020) no servidor do IPEA
url_teste <- "https://github.com/ipeaGIT/geobr/releases/download/v1.7.0/mg_municipality_2020.gpkg"
# Tentando baixar diretamente
download.file(url = url_teste, destfile = destino_teste, mode = "wb")
options(timeout = 300)
url_teste <- "https://github.com/ipeaGIT/geobr/releases/download/v1.7.0/mg_municipality_2020.gpkg"
download.file(url = url_teste, destfile = tempfile(fileext = ".gpkg"), mode = "wb")
options(download.file.method = "libcurl")
options(timeout = 300)
# 2. O LINK CORRETO E ATUALIZADO (Direto do servidor oficial do IPEA)
url_correta <- "https://www.ipea.gov.br/geobr/data_gpkg/municipio/2020/31M.gpkg"
# 3. Tenta o download novamente
download.file(url = url_correta, destfile = tempfile(fileext = ".gpkg"), mode = "wb")
# 1. Destrói qualquer resquício de pastas temporárias desta sessão
unlink(file.path(tempdir(), "geobr"), recursive = TRUE, force = TRUE)
# 2. Apaga o cache de internet que o RStudio faz em segundo plano
if (exists(".rs.downloadFile")) {
rm(list = ls(envir = as.environment("tools:rstudio")), envir = as.environment("tools:rstudio"), all.names = TRUE)
}
# 1. Puxando os anos reais disponíveis no IBGE (2022 a 2024)
dados_sidra <- get_sidra(
x = 1612,
variable = 112,
classific = "c81",
category = list(2713),
geo = "City",
geo.filter = list("State" = 31),
period = c("2022", "2023", "2024")
)
