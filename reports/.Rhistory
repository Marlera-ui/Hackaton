library(tidyverse)
library(tidyr)
library(sidrar)#
library(geobr)#
library(sf)#
library(nasapower)
library(janitor)
library(lubridate)
library(dplyr)#
library(readxl)
library(leaflet)
library(scales)
library(stringr)#
library(ggplot2)#
library(knitr)
library(htmltools)
# ============================================================
# 2. MUNICÍPIOS DE MINAS GERAIS + COORDENADAS
# ============================================================
mg_municipios <- read_municipality(
code_muni = "MG",
year = 2020,
simplified = TRUE
)
mg_centroides <- mg_municipios |>
st_centroid() |>
mutate(
longitude = st_coordinates(geometry)[, 1],
latitude  = st_coordinates(geometry)[, 2]
) |>
st_drop_geometry() |>
select(
cod_ibge = code_muni,
municipio = name_muni,
longitude,
latitude
)
