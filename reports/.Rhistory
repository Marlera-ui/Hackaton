mutate(code_muni_6d = stringr::str_sub(as.character(codigo_ibge), 1, 6)),
by = "code_muni_6d"
) %>%
mutate(prod_atingivel = as.numeric(prod_atingivel)) %>%
filter(!is.na(prod_atingivel)) %>%
# Ordena do maior para o menor quilo por hectare real e pega o Top 10
arrange(desc(prod_atingivel)) %>%
slice(1:10) %>%
# Passo 1: Busca o clima e calcula a severidade epidemiológica via API da NASA
rowwise() %>%
mutate(
data_deteccao = as.Date("2023-12-01"),
chuva_real_30d = sum(get_power(
community = "ag",
lonlat = c(longitude, latitude),
pars = "PRECTOTCORR",
dates = c(data_deteccao, data_deteccao + 30),
temporal_api = "daily"
)$PRECTOTCORR, na.rm = TRUE),
severidade_prevista = calcular_severidade(chuva_real_30d)
) %>%
ungroup() %>%
# Passo 2: Expande para os cenários de Momento do Surgimento da Doença (DOT)
expand_grid(cenario_dot = c("Precoce (<R1)", "Tardio (>=R1)")) %>%
# Passo 3: Cálculos matemáticos de perda e vulnerabilidade
mutate(
coef_dano = ifelse(cenario_dot == "Precoce (<R1)",
COEF_DANO_PRECOCE,
COEF_DANO_TARDIO),
perda_kg_ha = prod_atingivel * (coef_dano * severidade_prevista / 100),
vulnerabilidade_index = (severidade_prevista / 100) * prod_atingivel * perda_kg_ha
)
# Visualizando o resultado final
head(analise_risco)
grafico_ranking <- analise_risco %>%
# Garante que o gráfico ordene os municípios pelo maior índice de vulnerabilidade geral
mutate(name_muni = reorder(name_muni, vulnerabilidade_index, FUN = max)) %>%
ggplot(aes(x = name_muni, y = vulnerabilidade_index, fill = cenario_dot)) +
geom_col(position = position_dodge(width = 0.8), width = 0.7) +
coord_flip() +
labs(
title = "Ranking de Vulnerabilidade Municipal (Top 10 Maiores Produtores)",
subtitle = "Minas Gerais - Simulação Safra 2024/25",
x = "Município",
y = "Índice de Vulnerabilidade Financeira",
fill = "Momento da Infecção"
) +
scale_fill_viridis_d(option = "mako", begin = 0.3, end = 0.7) +
theme_minimal() +
theme(
panel.grid.minor = element_blank(),
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 14)
)
# Exibe o gráfico no RStudio
print(grafico_ranking)
# 1. Preparação dos dados espacializados com padronização de códigos para 6 dígitos
mapa_dados <- mg_municipios %>%
# Transforma o código do geobr em texto e pega apenas os 6 primeiros dígitos
mutate(code_muni_6d = str_sub(as.character(code_muni), 1, 6)) %>%
# Cruza com a análise de risco, aplicando a mesma padronização de 6 dígitos nela
left_join(
analise_risco %>%
filter(cenario_dot == "Precoce (<R1)") %>%
mutate(code_muni_6d = str_sub(as.character(code_muni), 1, 6)),
by = "code_muni_6d"
)
# 2. Definição da paleta de cores (Tratando os municípios sem dados 'NA')
pal <- colorNumeric(
palette = "YlOrRd",
domain = mapa_dados$perda_kg_ha,
na.color = "#E0E0E0" # Cinza claro para os municípios que não estão no Top 10
)
# 3. Construção do Mapa Interativo com Leaflet
mapa_final <- leaflet(mapa_dados) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addPolygons(
fillColor = ~pal(perda_kg_ha),
weight = 1,
color = "#8C8C8C",
fillOpacity = 0.85,
highlightOptions = highlightOptions(
weight = 3,
color = "#000000",
fillOpacity = 0.9,
bringToFront = TRUE
),
# Nota: Usamos name_muni.x (que veio do mapa) para garantir que o nome apareça mesmo se for NA
label = ~if_else(
is.na(perda_kg_ha),
paste0("<strong>", name_muni.x, "</strong><br>Dado não simulado (Fora do Top 10)"),
paste0(
"<strong>Município: </strong>", name_muni.x, "<br>",
"<strong>Prod. Atingível: </strong>", round(prod_atingivel), " kg/ha<br>",
"<strong>Chuva 30d: </strong>", round(chuva_real_30d, 1), " mm<br>",
"<strong>Severidade: </strong>", round(severidade_prevista, 1), "%<br>",
"<strong>Perda Estimada: </strong><span style='color:red;'>", round(perda_kg_ha), " kg/ha</span>"
)
) %>% lapply(htmltools::HTML),
labelOptions = labelOptions(
style = list("font-weight" = "normal", padding = "6px 12px"),
textsize = "13px",
direction = "auto"
)
) %>%
addLegend(
pal = pal,
values = ~perda_kg_ha,
title = "Perda Est. (kg/ha)<br><small>Cenário Precoce (<R1)</small>",
position = "bottomright",
na.label = "Não analisado"
)
# Exibe o mapa interativo no RStudio
mapa_final
potencias_soja <- c("Unaí", "Uberaba", "Paracatu", "Perdizes", "Patrocínio",
"Sacramento", "Uberlândia", "Araguari", "Buritis", "Coromandel")
analise_risco <- mg_centroides %>%
# Padroniza o código dos centroides para 6 dígitos
mutate(code_muni_6d = stringr::str_sub(as.character(code_muni), 1, 6)) %>%
# Faz o mesmo na tabela do SIDRA para garantir o cruzamento perfeito
inner_join(
produtividade_atingivel %>%
mutate(code_muni_6d = stringr::str_sub(as.character(codigo_ibge), 1, 6)),
by = "code_muni_6d"
) %>%
mutate(prod_atingivel = as.numeric(prod_atingivel)) %>%
filter(!is.na(prod_atingivel)) %>%
# Filtra os Top 10 municípios mais produtores por nome
filter(name_muni %in% potencias_soja) %>%
# Passo 1: Busca o clima e calcula a severidade epidemiológica via API da NASA
rowwise() %>%
mutate(
data_deteccao = as.Date("2023-12-01"),
chuva_real_30d = sum(get_power(
community = "ag",
lonlat = c(longitude, latitude),
pars = "PRECTOTCORR",
dates = c(data_deteccao, data_deteccao + 30),
temporal_api = "daily"
)$PRECTOTCORR, na.rm = TRUE),
severidade_prevista = calcular_severidade(chuva_real_30d)
) %>%
ungroup() %>%
# Passo 2: Expande para os cenários de Momento do Surgimento da Doença (DOT)
expand_grid(cenario_dot = c("Precoce (<R1)", "Tardio (>=R1)")) %>%
# Passo 3: Cálculos matemáticos de perda e vulnerabilidade
mutate(
coef_dano = ifelse(cenario_dot == "Precoce (<R1)",
COEF_DANO_PRECOCE,
COEF_DANO_TARDIO),
perda_kg_ha = prod_atingivel * (coef_dano * severidade_prevista / 100),
vulnerabilidade_index = (severidade_prevista / 100) * prod_atingivel * perda_kg_ha
)
# Visualizando o resultado final
head(analise_risco)
grafico_ranking <- analise_risco %>%
# Garante que o gráfico ordene os municípios pelo maior índice de vulnerabilidade geral
mutate(name_muni = reorder(name_muni, vulnerabilidade_index, FUN = max)) %>%
ggplot(aes(x = name_muni, y = vulnerabilidade_index, fill = cenario_dot)) +
geom_col(position = position_dodge(width = 0.8), width = 0.7) +
coord_flip() +
labs(
title = "Ranking de Vulnerabilidade Municipal (Top 10 Maiores Produtores)",
subtitle = "Minas Gerais - Simulação Safra 2024/25",
x = "Município",
y = "Índice de Vulnerabilidade Financeira",
fill = "Momento da Infecção"
) +
scale_fill_viridis_d(option = "mako", begin = 0.3, end = 0.7) +
theme_minimal() +
theme(
panel.grid.minor = element_blank(),
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 14)
)
# Exibe o gráfico no RStudio
print(grafico_ranking)
